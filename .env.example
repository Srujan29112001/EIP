# Application Configuration
APP_NAME=EIP
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-this-in-production

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=True

# Database - PostgreSQL
DATABASE_URL=postgresql://eip_user:eip_password@localhost:5432/eip_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Database - MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=eip_documents

# Database - Neo4j (GraphRAG)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Database - Redis (Memory)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
SESSION_TTL=3600

# Vector Store - Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=eip-documents

# Alternative Vector Store - Chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=eip_embeddings

# LLM APIs
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Model Configuration
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large
MAX_TOKENS=4000
TEMPERATURE=0.7

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=eip-consumers
KAFKA_NEWS_TOPIC=news_stream
KAFKA_MARKET_TOPIC=market_stream
KAFKA_POLICY_TOPIC=policy_stream
KAFKA_USER_EVENTS_TOPIC=user_events

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_APP_NAME=EIP-DataPipeline

# Airflow Configuration
AIRFLOW_HOME=/opt/airflow
AIRFLOW_DAGS_FOLDER=/opt/airflow/dags
AIRFLOW_EXECUTOR=CeleryExecutor
AIRFLOW_FERNET_KEY=your-fernet-key

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=eip-experiments
MLFLOW_S3_ENDPOINT_URL=

# AWS Configuration (for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=eip-data-bucket

# GCP Configuration (alternative)
GCP_PROJECT_ID=
GCP_CREDENTIALS_PATH=
GCS_BUCKET_NAME=

# External APIs
NEWS_API_KEY=your-newsapi-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
GOOGLE_NEWS_API_KEY=

# Authentication
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501"]

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# OCR Configuration
TESSERACT_PATH=/usr/bin/tesseract
OCR_LANGUAGE=eng

# Email Configuration (for reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@eip-platform.com

# Celery (for async tasks)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Feature Flags
ENABLE_GRAPHRAG=True
ENABLE_POLICY_MONITORING=True
ENABLE_MARKET_ANALYSIS=True
ENABLE_DOCUMENT_INTELLIGENCE=True

# Cache Configuration
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300
