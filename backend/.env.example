# ── EIP backend configuration ────────────────────────────────────────────────
# Everything is optional. With nothing set, EIP runs in demo/deterministic mode.

# Local GPU (Ollama). Install https://ollama.com then: ollama pull qwen3:4b
EIP_OLLAMA_URL=http://localhost:11434
EIP_LOCAL_MODEL=qwen3:4b

# Cloud providers — add any ONE (or more) to unlock full reasoning depth.
# EIP_ANTHROPIC_API_KEY=
# EIP_OPENAI_API_KEY=
# EIP_GOOGLE_API_KEY=
# EIP_DEEPSEEK_API_KEY=
# EIP_GROQ_API_KEY=
# EIP_OPENROUTER_API_KEY=

# Optional explicit routing (tier = t1 mechanical | t2 analysis | t3 reasoning)
# Format: provider:model      e.g.  EIP_T3_ROUTE=anthropic:claude-sonnet-4-5
# EIP_T1_ROUTE=ollama:qwen3:4b
# EIP_T2_ROUTE=groq:llama-3.3-70b-versatile
# EIP_T3_ROUTE=anthropic:claude-sonnet-4-5

# CORS (comma separated). Defaults cover local dev + Vercel.
# EIP_CORS_ORIGINS=http://localhost:3000
